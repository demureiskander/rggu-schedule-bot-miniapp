# Upstream базы официального API РГГУ (заказчик берёт из кода бота @RsuhSpaceBot).
# Без слэша в конце. Прокси форвардит сюда POST Get_Flows_List / Get_Schedule_Table.
API_URL=https://CHANGE_ME-rggu-api-base

# Порт. На Railway передаётся автоматически — локально по умолчанию 3000.
PORT=3000

# Origin для CORS. '*' допустимо (расписание публичное) или домен GitHub Pages.
ALLOW_ORIGIN=*
